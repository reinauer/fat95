BlocksPerTrack	= 9
Buffers		= 20
BufMemType	= 1
BootPri		= 0
Stacksize	= 2048
Priority	= 5
GlobVec		= -1
DosType		= 0x46415400	/* enable ETD commands */
Mount		= 1		/* ha 0-ra állítod, akkor a meghajtó */
