/* Néhány MountList példa AMIGA felhasználóknak dedikálva */


/* külső IOmega Zip 100 meghajtó A1200 toronyban */
/* B1260, IOblixZII, OS3.5/Scalos/DOpus 5.82 Magellan II */
/* Köszönet Gunter Hinrichsennek */

ZIPC:
FileSystem      = L:fat95
Flags           = 1
Surfaces        = 1
BlocksPerTrack  = 68
Reserved        = 0
PreAlloc        = 0
Interleave      = 0
LowCyl          = 0
HighCyl         = 2890
Buffers         = 100
BufMemType      = 1
MaxTransfer     = 0x00ffffff
Mask            = 0xffffffff
DosType         = 0x46415401
GlobVec         = -1
StackSize       = 8192
Mount           = 1
Priority        = 10
Device          = ioblixzip.device
Unit            = 1
#


/* Catwesel-Zorro2 DD/HD floppy adapter */
/* Köszönet Jens Schrödernek */

/* multidisk file system entry
 * Minta egy logikai egység létrehozására Catweasel 0. meghajtóba,
 * MS-DOS 9 szektoros lemez írás/olvasásához. Más meghajtók létrehozásához
 * cseréld ki az egységszámot az "UNIT =" sorban (0, 1 vagy 2).
 */

MS4DD:
FileSystem     = L:fat95
Device         = multidisk.device
Unit           = 0 /* Unit 0 or 1 */
Flags          = 2 /* PC DD-s Lemez meghajtó */
BlockSize      = 512
Surfaces       = 2
BlocksPerTrack = 9
Reserved       = 1
Interleave     = 0
LowCyl         = 0
HighCyl        = 79
Buffers        = 20
BufMemType     = 1
StackSize      = 4096
Priority       = 5
GlobVec        = -1
DosType        = 0x46415401
Activate       = 1
#

MS4HD:
FileSystem     = L:fat95
Device         = multidisk.device
Unit           = 0 /* Unit 0 or 1 */
Flags          = 3 /* PC HD-s Lemez meghajtó */
Surfaces       = 2
BlocksPerTrack = 18
Reserved       = 1
Interleave     = 0
LowCyl         = 0
HighCyl        = 79
Buffers        = 40
Stacksize      = 4096
BufMemType     = 1
Priority       = 5
GlobVec        = -1
DosType        = 0x46415401
Activate       = 1 /*=  mount = 1 */
#


/* MO (magneto-optical disk)				   */
/* Fujitsu MO 640 MByte 2048 bytes/sector direkt felülírás */
/* Köszönet H.J.Pinkertnek				   */

FATMOCYB:
FileSystem	= L:fat95
Buffers		= 100
BufMemType	= 1
Device		= cybscsi.device
Unit		= 2 
StackSize	= 4096
Priority	= 10
GlobVec		= -1
DosType		= 0x46415401
Surfaces	= 1
BlocksPerTrack	= 1
LowCyl		= 0
HighCyl		= 1
Mask		= 0xFFFFFFFF
MaxTransfer 	= 0x00FFFFFF
mount		= 1
Activate	= 1
#


/* A DD floppy meghajtó az én A1200-esemben */

MS0:
FileSystem	= l:fat95
Device		= mfm.device
Unit		= 0
Flags		= 0
LowCyl		= 0
HighCyl		= 0
Surfaces	= 0
BlocksPerTrack	= 0
BlockSize	= 0
Buffers		= 20
BufMemType	= 1
BootPri		= 0
Stacksize	= 4096
Priority	= 5
GlobVec		= -1
DosType		= 0x46415401
#


/* 100 Mb NEC ZIP meghajtó az A1200-asom beépített IDE portján */

ZIP0:
FileSystem	= l:fat95
Device		= scsi.device
Unit		= 1
Flags		= 0
LowCyl		= 0
HighCyl		= 0
Surfaces	= 1
BlocksPerTrack	= 1
BlockSize	= 512
Buffers		= 100
BufMemType	= 1
BootPri		= 0
Stacksize	= 4096
Priority	= 5
GlobVec		= -1
DosType		= 0x46415401
Control		= "+s"		/* teszt: SCSI direkt parancsok */
#

