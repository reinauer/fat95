[locale]
;Here come the user interface texts.
;Some of them do contain "wild cards" showing fat95
;where it shall insert special information.
;"%s"  stands for text, like a volume name.
;"%ld" is a signed number, like an error code.
;"%lu" is an (unsigned) disk block number.
;"\n"  makes two text lines out of one.

;The error requester choices.
 1 = Megszakít
 2 = Átlép
 3 = Újra

;Some error messages.
 4 = Tedd vissza a következő lemezt: \n"%s"!
 5 = %s:\nolvasási hiba %ld a %lu. blokkban.
 6 = %s:\nírási hiba %ld a %lu. blokkban.
 7 = %s:\nfrissítési hiba %ld.

;Extended datestamp info as file comments.
 8 = Készült:
 9 = Utolsó hozzáférés:

;The !scandisk feature.
10 = Könyvtárak ellenőrzése...
11 = FAT tábla ellenőrzése...
12 = Elveszett fájlok keresése...
13 = %lu hiba kijavítva!
14 = Minden rendben! :)

;The !erase feature.
15 = A szabad lemezterület törlése...
16 = A megszakításhoz nyomd meg az <ESC> gombot!


