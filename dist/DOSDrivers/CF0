/* CF0: first FAT partition on a CompactFlash card.        */
/*                                                         */
/* The FileSystem = l:fat95 line is required by AmigaOS    */
/* Mount even when fat95 is ROM-resident: it satisfies the */
/* parser, and FileSystem.resource dedup ensures the ROM   */
/* SegList is the one DOS actually uses (see README        */
/* "Partition Selection" for the FAT\<n> DosType table).   */

FileSystem = l:fat95
Control = "-d-D"
Device = compactflash.device
Unit = 0
Flags = 0
LowCyl = 0
HighCyl = 0
Surfaces = 1
BlocksPerTrack = 1
BlockSize = 512
Buffers = 20
BufMemType = 1
BootPri = 0
Stacksize = 4096
Priority = 5
GlobVec = -1
DosType = 0x46415401
